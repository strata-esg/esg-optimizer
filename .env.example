# ================================================================
#  ESG Optimizer MVP — Variables d'environnement (.env.example)
# ----------------------------------------------------------------
#  Dev local :     cp .env.example .env  puis remplir
#  Prod Railway :  définir ces variables dans l'onglet "Variables"
# ================================================================

# --- Environnement ----------------------------------------------
ENVIRONMENT=development         # "development" ou "production"
LOG_LEVEL=info                  # debug | info | warning | error

# --- URLs publiques ---------------------------------------------
APP_URL=https://esg-optimizer.fr
SUPPORT_EMAIL=hello@esg-optimizer.fr
NOREPLY_EMAIL=no-reply@esg-optimizer.fr

# --- Config interne container (ne pas modifier sur Railway) -----
API_BASE_URL=http://localhost:8000
PORT_API=8000
API_WORKERS=2
# PORT est fourni automatiquement par Railway (ne pas définir)

# --- OpenAI ------------------------------------------------------
OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxx

# --- JWT (authentification) -------------------------------------
# Générer un secret long via : python -c "import secrets;print(secrets.token_urlsafe(48))"
JWT_SECRET=CHANGE_ME_TO_A_RANDOM_48_CHAR_STRING
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# --- Database ---------------------------------------------------
# Local : SQLite. Production Railway : utiliser le plugin Postgres
DATABASE_URL=sqlite:///./data/esg_optimizer.db
# DATABASE_URL=postgresql+pg8000://user:pass@host:5432/dbname

# --- Upload & limites -------------------------------------------
MAX_UPLOAD_SIZE_MB=20
MAX_TEXT_LENGTH=30000

# --- Plans & quotas ---------------------------------------------
DISCOVERY_TOTAL_LIMIT=1

# --- Quick-check public -----------------------------------------
PUBLIC_UPLOAD_MAX_MB=10
PUBLIC_RATE_LIMIT_DAILY=3
PUBLIC_RATE_LIMIT_WEEKLY=10
PUBLIC_TOKEN_EXPIRY_HOURS=72

# --- Analytics (Umami ou Plausible) ------------------------------
PLAUSIBLE_DOMAIN=esg-optimizer.fr

# --- Email transactionnel (Resend) ------------------------------
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx

# --- Paiements (Stripe) -----------------------------------------
STRIPE_SECRET_KEY=sk_live_xxxxxxxxxxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxx
STRIPE_LINK_ESSENTIEL=https://buy.stripe.com/xxxxxxxxxx
STRIPE_LINK_PRO=https://buy.stripe.com/xxxxxxxxxx

# --- Cron API key (pour /email/weekly-digest) -------------------
# Générer : python -c "import secrets;print(secrets.token_urlsafe(32))"
CRON_API_KEY=CHANGE_ME_TO_A_RANDOM_32_CHAR_STRING

# --- Monitoring erreurs (Sentry) — Sprint 6H --------------------
# Récupérer sur https://sentry.io — plan gratuit 5k events/mois
SENTRY_DSN=https://xxxxxxxxxxxx@oXXXXXX.ingest.sentry.io/XXXXXXX
