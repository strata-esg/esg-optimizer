# ============================================
# ESG Optimizer MVP — Variables d'environnement
# ============================================
# Copier ce fichier en .env et remplir les valeurs

# --- OpenAI ---
OPENAI_API_KEY=sk-...

# --- JWT Auth ---
JWT_SECRET=CHANGE_ME_TO_A_RANDOM_32_CHAR_STRING
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# --- Database ---
DATABASE_URL=sqlite:///./data/esg_optimizer.db

# --- Upload ---
MAX_UPLOAD_SIZE_MB=20
MAX_TEXT_LENGTH=30000

# --- Plans & quotas ---
DISCOVERY_TOTAL_LIMIT=1

# --- Analytics (Plausible) ---
PLAUSIBLE_DOMAIN=

# --- Stripe ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_LINK_ESSENTIEL=
STRIPE_LINK_PRO=

# --- Email (Resend) ---
RESEND_API_KEY=

# --- Monitoring (Sentry) ---
SENTRY_DSN=

# --- Quick-check public ---
PUBLIC_UPLOAD_MAX_MB=10
PUBLIC_RATE_LIMIT_DAILY=3
PUBLIC_RATE_LIMIT_WEEKLY=10
PUBLIC_TOKEN_EXPIRY_HOURS=72

# --- Environment ---
ENVIRONMENT=development
