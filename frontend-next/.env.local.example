# ============================================================
# ESG Optimizer — Variables d'environnement Next.js
# Copier ce fichier en .env.local et remplir les valeurs
# ⚠️ Ne jamais committer .env.local (déjà dans .gitignore)
# ============================================================

# ── Clerk (https://dashboard.clerk.com) ─────────────────────
# Récupérer dans : Clerk Dashboard → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
CLERK_SECRET_KEY=sk_test_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Webhook secret (Clerk Dashboard → Webhooks → ton endpoint)
CLERK_WEBHOOK_SECRET=whsec_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Routes Clerk
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# ── Supabase (https://app.supabase.com) ─────────────────────
# Récupérer dans : Supabase Dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://XXXXXXXXXXXXXXXX.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Service role — SERVEUR UNIQUEMENT (ne pas préfixer NEXT_PUBLIC_)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── FastAPI Backend (Railway) ────────────────────────────────
# URL de ton backend Railway (sans slash final)
NEXT_PUBLIC_API_URL=https://ton-app.railway.app

# ── Stripe (optionnel — pour les Payment Links) ─────────────
NEXT_PUBLIC_STRIPE_ESSENTIAL_URL=https://buy.stripe.com/XXXXXXXX
NEXT_PUBLIC_STRIPE_PRO_URL=https://buy.stripe.com/YYYYYYYY
